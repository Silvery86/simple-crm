# =============================================================================
# Simple CRM — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# RULES:
# - .env.local is NEVER committed to git (see .gitignore)
# - NEXT_PUBLIC_* variables are exposed to the browser — never put secrets there
# - Rotate any secret immediately if accidentally committed
# - All vars documented here must also be set in Vercel (preview + production)
# - See .docs/INTEGRATION_FLOWS.md Section 9 for full integration variable reference
# =============================================================================

# =============================================================================
# DATABASE (Neon DB / PostgreSQL)
# =============================================================================

# Pooled connection — used by Prisma in all server-side queries
# Format: postgresql://[user]:[password]@[pooler-host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Direct connection — used by Prisma for migrations only (bypasses PgBouncer)
# Format: postgresql://[user]:[password]@[direct-host]/[dbname]?sslmode=require
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# =============================================================================
# UPSTASH REDIS
# =============================================================================

# Redis connection URL — used for auth token caching and rate limiting
# Format: rediss://:[password]@[host]:6380
REDIS_URL="rediss://:password@us1-xxx.upstash.io:6380"

# =============================================================================
# FIREBASE AUTH
# =============================================================================

# Firebase project configuration (public — safe for NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:xxxxxxxxxxxxxxxxxxxx"

# Firebase Admin SDK — server-side only (never NEXT_PUBLIC_)
# Base64-encoded service account JSON:
#   base64 -i your-service-account.json | tr -d '\n'
FIREBASE_ADMIN_CREDENTIALS="eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6..."

# =============================================================================
# APPLICATION
# =============================================================================

# Public app URL — used to construct absolute URLs for job processor endpoints
# No trailing slash
NEXT_PUBLIC_APP_URL="https://your-crm.vercel.app"

# =============================================================================
# SECURITY — CREDENTIAL ENCRYPTION
# =============================================================================
# updated: multi-tenant-uc1-7

# AES-256-GCM master key for encrypting WooCommerce API credentials in DB.
# Each store's consumer_key, consumer_secret, and webhook_secret are encrypted
# with this key and stored in the StoreCredential table.
#
# IMPORTANT: This key is NOT the same as ENCRYPTION_KEY (legacy, now unused).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER commit the real value. NEVER rotate without running npm run migrate:re-encrypt first.
CREDENTIAL_ENCRYPTION_KEY="base64-encoded-32-bytes-here"

# NOTE: WOOCOMMERCE_BASE_URL / WOOCOMMERCE_CONSUMER_KEY / WOOCOMMERCE_CONSUMER_SECRET /
# WOOCOMMERCE_WEBHOOK_SECRET are NO LONGER environment variables.
# They are stored per-store in the StoreCredential table, encrypted with CREDENTIAL_ENCRYPTION_KEY.
# Each store's credentials are entered via the UI (Dashboard → Add Store) and saved encrypted.

# =============================================================================
# IMAGE STORAGE — VERCEL BLOB (UC5: Product Import)
# =============================================================================

# Vercel Blob read/write token — used for downloading and re-uploading product images during UC5.
# Provision via: Vercel Dashboard → Storage → Blob → Create Store → Copy token.
# Required for Phase 3 (UC5 import module). Not needed for Phase 1 or 2.
VERCEL_BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"

# =============================================================================
# UPSTASH QSTASH — used by all job processor routes (Flows 1–5)
# =============================================================================

# QStash publish endpoint — do not change this value
QSTASH_URL="https://qstash.upstash.io/v2/publish/"

# QStash bearer token — from Upstash console: QStash → Details → Token
QSTASH_TOKEN="eyJVc2VySUQiOiJYWFhYWFhYWC1YWFhYLVhYWFgtWFhYWC1YWHH..."

# QStash request signing keys — from Upstash console: QStash → Details → Signing Keys
# Used by verifySignatureAppRouter() to authenticate incoming QStash deliveries
# CURRENT_SIGNING_KEY: active key
# NEXT_SIGNING_KEY: rotated-in key (supports zero-downtime key rotation)
QSTASH_CURRENT_SIGNING_KEY="sig_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
QSTASH_NEXT_SIGNING_KEY="sig_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# =============================================================================
# JOB PROCESSOR URLS — full public URLs for QStash cron targets
# =============================================================================
# These are set automatically in production based on NEXT_PUBLIC_APP_URL.
# In Vercel, set to the deployment URL for each environment.
# Format: {NEXT_PUBLIC_APP_URL}/api/jobs/{job-name}
# =============================================================================

# Flow 2 — Order reconciliation cron (*/5 * * * *)
JOB_RECONCILE_ORDERS_URL="https://your-crm.vercel.app/api/jobs/reconcile-orders"

# Flow 3 — Product sync cron (*/30 * * * *)
JOB_SYNC_PRODUCTS_URL="https://your-crm.vercel.app/api/jobs/sync-products"

# Flow 4 — Product push outbound cron (0 * * * *)
JOB_PUSH_PRODUCTS_URL="https://your-crm.vercel.app/api/jobs/push-products"

# Flow 5 — Error detection cron (*/30 * * * *)
JOB_DETECT_ERRORS_URL="https://your-crm.vercel.app/api/jobs/detect-errors"

# UC1 — Initial sync jobs (triggered once when a store is first connected, no cron)
JOB_INITIAL_SYNC_ORDERS_URL="https://your-crm.vercel.app/api/jobs/initial-sync-orders"
JOB_INITIAL_SYNC_PRODUCTS_URL="https://your-crm.vercel.app/api/jobs/initial-sync-products"
JOB_INITIAL_SYNC_CUSTOMERS_URL="https://your-crm.vercel.app/api/jobs/initial-sync-customers"

# =============================================================================
# NEW WEBSITE API — Flow 4 (⚠ PENDING API CONTRACT CONFIRMATION)
# =============================================================================
# These variables are stubs until PM confirms the new website API contract.
# Do not implement Flow 4 until both variables are confirmed.
# See .docs/INTEGRATION_FLOWS.md §6 for the 5 contract questions.

# New website API base URL (no trailing slash)
NEW_WEBSITE_API_URL="https://api.new-website.example.com"

# API authentication key (method TBD — may be header, OAuth, or bearer token)
NEW_WEBSITE_API_KEY="your_new_website_api_key_here"

# =============================================================================
# PHASE 2 — Order Tracking & Logistics (not yet required)
# =============================================================================

# AfterShip API key — for shipment tracking webhooks (Phase 2)
# Get from: AfterShip dashboard → Settings → API Keys
# AFTERSHIP_API_KEY="your_aftership_api_key_here"

# =============================================================================
# PHASE 3 — Email Marketing & AI Content (not yet required)
# =============================================================================

# Mailjet API credentials — for transactional email (Phase 3)
# Get from: Mailjet → Account → REST API → Primary key
# MAILJET_API_KEY="your_mailjet_api_key_here"
# MAILJET_SECRET_KEY="your_mailjet_secret_key_here"

# Google Gemini API key — for AI content generation (Phase 3)
# Get from: Google Cloud Console → APIs & Services → Credentials
# GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Google Drive API — for asset storage and sharing (Phase 3)
# Get from: Google Cloud Console → Service Accounts
# GOOGLE_DRIVE_CREDENTIALS="eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6..."
# GOOGLE_DRIVE_FOLDER_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs"
